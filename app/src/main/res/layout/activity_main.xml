<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCF7FC"
    android:focusableInTouchMode="true"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingTop="10dp"
    android:paddingEnd="12dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:id="@+id/panelControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="42dp"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:text="&#x73af;&#x5883;"
                android:textColor="#6F6874"
                android:textSize="13sp" />

            <AutoCompleteTextView
                android:id="@+id/spEnvironment"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_compact_field"
                android:inputType="none"
                android:paddingStart="10dp"
                android:paddingEnd="8dp"
                android:singleLine="true"
                android:textColor="#27222B"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnRun"
                android:layout_width="96dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_run_button"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="&#x6267;&#x884c;"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:layout_marginTop="6dp"
            android:gravity="bottom"
            android:text="&#x8bbe;&#x5907; ID&#xff08;&#x6bcf;&#x884c;&#x4e00;&#x4e2a;&#xff0c;&#x6216;&#x7528;&#x9017;&#x53f7;/&#x7a7a;&#x683c;&#x5206;&#x9694;&#xff09;"
            android:textColor="#6F6874"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/etDevices"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_compact_field"
            android:gravity="top|start"
            android:inputType="textMultiLine|textNoSuggestions"
            android:minHeight="0dp"
            android:paddingStart="10dp"
            android:paddingTop="5dp"
            android:paddingEnd="10dp"
            android:paddingBottom="4dp"
            android:textColor="#27222B"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="42dp"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:text="&#x5f00;&#x59cb;"
                android:textColor="#6F6874"
                android:textSize="13sp" />

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_compact_field">

                <EditText
                    android:id="@+id/etFrom"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:inputType="date"
                    android:minHeight="0dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="36dp"
                    android:singleLine="true"
                    android:textColor="#27222B"
                    android:textSize="14sp" />

                <ImageButton
                    android:id="@+id/btnPickFrom"
                    android:layout_width="34dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="end|center_vertical"
                    android:background="@android:color/transparent"
                    android:contentDescription="&#x9009;&#x62e9;&#x5f00;&#x59cb;&#x65e5;&#x671f;"
                    android:padding="7dp"
                    android:scaleType="centerInside"
                    android:src="@android:drawable/ic_menu_my_calendar"
                    android:tint="#6F6874" />
            </FrameLayout>

            <AutoCompleteTextView
                android:id="@+id/acFromHour"
                android:layout_width="58dp"
                android:layout_height="match_parent"
                android:layout_marginStart="5dp"
                android:background="@drawable/bg_compact_field"
                android:gravity="center"
                android:inputType="none"
                android:padding="0dp"
                android:singleLine="true"
                android:textColor="#27222B"
                android:textSize="14sp" />

            <AutoCompleteTextView
                android:id="@+id/acFromMinute"
                android:layout_width="58dp"
                android:layout_height="match_parent"
                android:layout_marginStart="5dp"
                android:background="@drawable/bg_compact_field"
                android:gravity="center"
                android:inputType="none"
                android:padding="0dp"
                android:singleLine="true"
                android:textColor="#27222B"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:layout_marginTop="5dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="42dp"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:text="&#x7ed3;&#x675f;"
                android:textColor="#6F6874"
                android:textSize="13sp" />

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_compact_field">

                <EditText
                    android:id="@+id/etTo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:inputType="date"
                    android:minHeight="0dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="36dp"
                    android:singleLine="true"
                    android:textColor="#27222B"
                    android:textSize="14sp" />

                <ImageButton
                    android:id="@+id/btnPickTo"
                    android:layout_width="34dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="end|center_vertical"
                    android:background="@android:color/transparent"
                    android:contentDescription="&#x9009;&#x62e9;&#x7ed3;&#x675f;&#x65e5;&#x671f;"
                    android:padding="7dp"
                    android:scaleType="centerInside"
                    android:src="@android:drawable/ic_menu_my_calendar"
                    android:tint="#6F6874" />
            </FrameLayout>

            <AutoCompleteTextView
                android:id="@+id/acToHour"
                android:layout_width="58dp"
                android:layout_height="match_parent"
                android:layout_marginStart="5dp"
                android:background="@drawable/bg_compact_field"
                android:gravity="center"
                android:inputType="none"
                android:padding="0dp"
                android:singleLine="true"
                android:textColor="#27222B"
                android:textSize="14sp" />

            <AutoCompleteTextView
                android:id="@+id/acToMinute"
                android:layout_width="58dp"
                android:layout_height="match_parent"
                android:layout_marginStart="5dp"
                android:background="@drawable/bg_compact_field"
                android:gravity="center"
                android:inputType="none"
                android:padding="0dp"
                android:singleLine="true"
                android:textColor="#27222B"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/txtLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:fontFamily="monospace"
        android:gravity="top|start"
        android:scrollbars="vertical"
        android:text="&#x65e5;&#x5fd7;&#x8f93;&#x51fa;"
        android:textColor="#4C4651"
        android:textIsSelectable="true"
        android:textSize="12sp" />
</LinearLayout>
